<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_pipinos_pelanggan" model="ir.actions.act_window">
        <field name="name">Master Data Pelanggan</field>
        <field name="res_model">pipinos.pelanggan</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_pelanggan_tree" model="ir.ui.view">
        <field name="name">pipinos.pelanggan.tree</field>
        <field name="model">pipinos.pelanggan</field>
        <field name="arch" type="xml">
            <tree>
                <field name="nama_lengkap"/>
                <field name="no_hp"/>
                <field name="favorite_menu_id"/>
            </tree>
        </field>
    </record>

    <record id="view_pelanggan_form" model="ir.ui.view">
        <field name="name">pipinos.pelanggan.form</field>
        <field name="model">pipinos.pelanggan</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="id_pelanggan" readonly="1"/></h1>
                    </div>
                    <group>
                        <field name="nama_depan"/>
                        <field name="nama_belakang"/>
                        <field name="no_hp"/>
                        <field name="segmen_ids" widget="many2many_tags"/>
                    </group>
                    
                    <notebook>
                        <page string="Data Demografi">
                            <group>
                                <field name="usia_input"/>
                                <field name="gender_input"/>
                            </group>
                        </page>
                        <page string="Status Loyalty">
                            <group>
                                <field name="total_poin_input"/>
                                <field name="status_level_output" widget="badge" decoration-warning="status_level_output=='gold'" decoration-info="status_level_output=='silver'"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_loyalty_level_config_tree" model="ir.ui.view">
        <field name="name">pipinos.loyalty.level.config.tree</field>
        <field name="model">pipinos.loyalty.level.config</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="threshold_points"/>
                <field name="active"/>
            </tree>
        </field>
    </record>
    
    <record id="view_loyalty_level_config_form" model="ir.ui.view">
        <field name="name">pipinos.loyalty.level.config.form</field>
        <field name="model">pipinos.loyalty.level.config</field>
        <field name="arch" type="xml">
            <form string="Konfigurasi Status Level Loyalty">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="threshold_points"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pipinos_loyalty_level_config" model="ir.actions.act_window">
        <field name="name">Konfigurasi Status Level Loyalty</field>
        <field name="res_model">pipinos.loyalty.level.config</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_loyalty_level_config_tree"/>
    </record>

    <!-- search biar bisa pk nama pelanggan -->
    <record id="view_pelanggan_search" model="ir.ui.view">
        <field name="name">pipinos.pelanggan.search</field>
        <field name="model">pipinos.pelanggan</field>
        <field name="arch" type="xml">
            <search>
                <field name="nama_lengkap" string="Pencarian Nama" filter_domain="['|', '|', ('nama_lengkap', 'ilike', self), ('nama_depan', 'ilike', self), ('nama_belakang', 'ilike', self)]"/>
                <field name="id_pelanggan" string="Cari ID Pelanggan"/>
                <field name="no_hp" string="Cari No Telp"/>
            </search>
        </field>
    </record>

    <record id="action_pipinos_loyalty" model="ir.actions.act_window">
        <field name="name">Sistem Loyalty (Kasir)</field>
        <field name="res_model">pipinos.loyalty.member</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_loyalty_tree" model="ir.ui.view">
        <field name="name">pipinos.loyalty.member.tree</field>
        <field name="model">pipinos.loyalty.member</field>
        <field name="arch" type="xml">
            <tree string="Daftar Member Loyalty">
                <field name="id_pelanggan" string="Nama Pelanggan"/>
                <field name="no_hp"/>
                <field name="total_poin"/>
                <field name="status_level" widget="badge" decoration-warning="status_level=='gold'" decoration-info="status_level=='silver'"/>
            </tree>
        </field>
    </record>

    <record id="view_loyalty_form" model="ir.ui.view">
        <field name="name">pipinos.loyalty.member.form</field>
        <field name="model">pipinos.loyalty.member</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="id_pelanggan" class="oe_edit_only" string="Nama Pelanggan"/>
                        <h1><field name="id_pelanggan" options="{'no_quick_create': True}"/></h1>
                    </div>
                    <group string="Evaluasi Status &amp; Reward">
                        <field name="no_hp" readonly="1"/>
                        <field name="total_poin"/>
                        <field name="status_level" widget="badge" decoration-warning="status_level=='gold'" decoration-info="status_level=='silver'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- search biar bisa pk nama pelanggan -->
    <record id="view_loyalty_search" model="ir.ui.view">
        <field name="name">pipinos.loyalty.member.search</field>
        <field name="model">pipinos.loyalty.member</field>
        <field name="arch" type="xml">
            <search>
                <field name="id_pelanggan" string="Cari Nama Pelanggan" filter_domain="['|', '|', ('id_pelanggan.nama_lengkap', 'ilike', self), ('id_pelanggan.nama_depan', 'ilike', self), ('id_pelanggan.nama_belakang', 'ilike', self)]"/>
                <field name="id_loyalty" string="Cari ID Loyalty"/>
            </search>
        </field>
    </record>

    <record id="view_dashboard_age_gender_graph" model="ir.ui.view">
        <field name="name">pipinos.demografi.dashboard.age.gender.graph</field>
        <field name="model">pipinos.demografi</field>
        <field name="arch" type="xml">
            <graph string="Avg Usia per Gender" type="bar">
                <field name="gender" type="row"/>
                <field name="usia" type="measure" operator="avg"/>
            </graph>
        </field>
    </record>

    <record id="action_pipinos_dashboard_age_gender" model="ir.actions.act_window">
        <field name="name">Avg Usia per Gender</field>
        <field name="res_model">pipinos.demografi</field>
        <field name="view_mode">graph,tree</field>
        <field name="view_id" ref="view_dashboard_age_gender_graph"/>
    </record>

    <record id="view_dashboard_gender_count_graph" model="ir.ui.view">
        <field name="name">pipinos.demografi.dashboard.gender.count.graph</field>
        <field name="model">pipinos.demografi</field>
        <field name="arch" type="xml">
            <graph string="Count per Gender" type="bar">
                <field name="gender" type="row"/>
            </graph>
        </field>
    </record>

    <record id="action_pipinos_dashboard_gender_count" model="ir.actions.act_window">
        <field name="name">Count per Gender</field>
        <field name="res_model">pipinos.demografi</field>
        <field name="view_mode">graph,tree</field>
        <field name="view_id" ref="view_dashboard_gender_count_graph"/>
    </record>

    <record id="view_dashboard_segment_graph" model="ir.ui.view">
        <field name="name">pipinos.terdaftar.dashboard.segment.graph</field>
        <field name="model">pipinos.terdaftar</field>
        <field name="arch" type="xml">
            <graph string="Segmen Pelanggan" type="bar">
                <field name="segmen_id" type="row"/>
            </graph>
        </field>
    </record>

    <record id="action_pipinos_dashboard_segment" model="ir.actions.act_window">
        <field name="name">Segmen Pelanggan</field>
        <field name="res_model">pipinos.terdaftar</field>
        <field name="view_mode">graph,tree</field>
        <field name="view_id" ref="view_dashboard_segment_graph"/>
    </record>

    <record id="view_dashboard_visit_graph" model="ir.ui.view">
        <field name="name">pipinos.transaksi.dashboard.visit.graph</field>
        <field name="model">pipinos.transaksi</field>
        <field name="arch" type="xml">
            <graph string="Frekuensi Kunjungan Pelanggan" type="bar">
                <field name="id_pelanggan" type="row"/>
            </graph>
        </field>
    </record>

    <record id="action_pipinos_dashboard_visit_frequency" model="ir.actions.act_window">
        <field name="name">Frekuensi Kunjungan Pelanggan</field>
        <field name="res_model">pipinos.transaksi</field>
        <field name="view_mode">graph,tree</field>
        <field name="view_id" ref="view_dashboard_visit_graph"/>
    </record>

    <record id="view_dashboard_status_graph" model="ir.ui.view">
        <field name="name">pipinos.loyalty.member.dashboard.status.graph</field>
        <field name="model">pipinos.loyalty.member</field>
        <field name="arch" type="xml">
            <graph string="Count Status Level" type="bar">
                <field name="status_level" type="row"/>
            </graph>
        </field>
    </record>

    <record id="action_pipinos_dashboard_status_level" model="ir.actions.act_window">
        <field name="name">Count Status Level</field>
        <field name="res_model">pipinos.loyalty.member</field>
        <field name="view_mode">graph,tree</field>
        <field name="view_id" ref="view_dashboard_status_graph"/>
    </record>

    <record id="view_dashboard_favorite_menu_pivot" model="ir.ui.view">
        <field name="name">pipinos.detail.transaksi.dashboard.favorite.menu.pivot</field>
        <field name="model">pipinos.detail.transaksi</field>
        <field name="arch" type="xml">
            <pivot string="Menu Favorit Pelanggan">
                <field name="id_pelanggan" type="row"/>
                <field name="id_menu" type="col"/>
                <field name="qty" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_pipinos_dashboard_favorite_menu" model="ir.actions.act_window">
        <field name="name">Menu Favorit Pelanggan</field>
        <field name="res_model">pipinos.detail.transaksi</field>
        <field name="view_mode">pivot,tree</field>
        <field name="view_id" ref="view_dashboard_favorite_menu_pivot"/>
    </record>

    <record id="view_dashboard_menu_count_graph" model="ir.ui.view">
        <field name="name">pipinos.detail.transaksi.dashboard.menu.count.graph</field>
        <field name="model">pipinos.detail.transaksi</field>
        <field name="arch" type="xml">
            <graph string="Count per Menu" type="bar">
                <field name="id_menu" type="row"/>
            </graph>
        </field>
    </record>

    <record id="action_pipinos_dashboard_menu_count" model="ir.actions.act_window">
        <field name="name">Count per Menu</field>
        <field name="res_model">pipinos.detail.transaksi</field>
        <field name="view_mode">graph,tree</field>
        <field name="view_id" ref="view_dashboard_menu_count_graph"/>
    </record>

    <record id="action_pipinos_menu" model="ir.actions.act_window">
        <field name="name">Master Data Menu</field>
        <field name="res_model">pipinos.item.menu</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_menu_tree" model="ir.ui.view">
        <field name="name">pipinos.item.menu.tree</field>
        <field name="model">pipinos.item.menu</field>
        <field name="arch" type="xml">
            <tree>
                <field name="nama_menu"/>
                <field name="kategori"/>
                <field name="harga"/>
            </tree>
        </field>
    </record>
    <record id="view_menu_form" model="ir.ui.view">
        <field name="name">pipinos.item.menu.form</field>
        <field name="model">pipinos.item.menu</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><h1><field name="id_menu" readonly="1"/></h1></div>
                    <group>
                        <field name="nama_menu"/>
                        <field name="kategori"/>
                        <field name="harga"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pipinos_kampanye" model="ir.actions.act_window">
        <field name="name">Master Data Kampanye</field>
        <field name="res_model">pipinos.kampanye</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_kampanye_tree" model="ir.ui.view">
        <field name="name">pipinos.kampanye.tree</field>
        <field name="model">pipinos.kampanye</field>
        <field name="arch" type="xml">
            <tree>
                <field name="nama_kampanye"/>
                <field name="tgl_mulai"/>
                <field name="tgl_selesai"/>
            </tree>
        </field>
    </record>
    <record id="view_kampanye_form" model="ir.ui.view">
        <field name="name">pipinos.kampanye.form</field>
        <field name="model">pipinos.kampanye</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><h1><field name="id_kampanye" readonly="1"/></h1></div>
                    <group>
                        <field name="nama_kampanye"/>
                        <field name="tgl_mulai"/>
                        <field name="tgl_selesai"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pipinos_segmen" model="ir.actions.act_window">
        <field name="name">Segmen Pelanggan</field>
        <field name="res_model">pipinos.segmen</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_segmen_tree" model="ir.ui.view">
        <field name="name">pipinos.segmen.tree</field>
        <field name="model">pipinos.segmen</field>
        <field name="arch" type="xml">
            <tree>
                <field name="nama_segmen"/>
                <field name="deskripsi"/>
            </tree>
        </field>
    </record>
    <record id="view_segmen_form" model="ir.ui.view">
        <field name="name">pipinos.segmen.form</field>
        <field name="model">pipinos.segmen</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><h1><field name="id_segmen" readonly="1"/></h1></div>
                    <group>
                        <field name="nama_segmen"/>
                        <field name="deskripsi"/>
                        <field name="kriteria"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_point_conversion_config_tree" model="ir.ui.view">
        <field name="name">pipinos.point.conversion.config.tree</field>
        <field name="model">pipinos.point.conversion.config</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="nominal_rupiah"/>
                <field name="point_value"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_point_conversion_config_form" model="ir.ui.view">
        <field name="name">pipinos.point.conversion.config.form</field>
        <field name="model">pipinos.point.conversion.config</field>
        <field name="arch" type="xml">
            <form string="Konfigurasi Konversi Poin">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="nominal_rupiah"/>
                        <field name="point_value"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pipinos_point_conversion_config" model="ir.actions.act_window">
        <field name="name">Konfigurasi Konversi Poin</field>
        <field name="res_model">pipinos.point.conversion.config</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_point_conversion_config_tree"/>
    </record>

    <record id="action_pipinos_transaksi" model="ir.actions.act_window">
        <field name="name">Data Transaksi</field>
        <field name="res_model">pipinos.transaksi</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_transaksi_tree" model="ir.ui.view">
        <field name="name">pipinos.transaksi.tree</field>
        <field name="model">pipinos.transaksi</field>
        <field name="arch" type="xml">
            <tree>
                <field name="tanggal"/>
                <field name="id_pelanggan"/>
                <field name="total_nominal"/>
            </tree>
        </field>
    </record>
    <record id="view_transaksi_form" model="ir.ui.view">
        <field name="name">pipinos.transaksi.form</field>
        <field name="model">pipinos.transaksi</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><h1><field name="id_transaksi" readonly="1"/></h1></div>
                    <group>
                        <group>
                            <field name="id_pelanggan" options="{'no_quick_create': True}" filter_domain="['|', '|', ('nama_lengkap', 'ilike', self), ('nama_depan', 'ilike', self), ('nama_belakang', 'ilike', self)]"/>
                            <field name="tanggal"/>
                        </group>
                        <group>
                            <field name="total_nominal"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Rincian Menu (D-03)">
                            <field name="detail_ids">
                                <tree editable="bottom">
                                    <field name="id_detail" readonly="1"/>
                                    <field name="id_menu"/>
                                    <field name="qty"/>
                                    <field name="subtotal"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem id="menu_pipinos_root" name="PIPINOS Customer Intelligence &amp; Loyalty System" sequence="10"/>
    
    <menuitem id="menu_admin_root" name="Admin (Manajemen)" parent="menu_pipinos_root" sequence="1"/>
    
    <menuitem id="menu_admin_master" name="Master Data" parent="menu_admin_root" sequence="1"/>
    <menuitem id="menu_admin_pelanggan" name="Data Pelanggan" parent="menu_admin_master" action="action_pipinos_pelanggan" sequence="1"/>
    <menuitem id="menu_admin_menu" name="Item Menu" parent="menu_admin_master" action="action_pipinos_menu" sequence="2"/>
    <menuitem id="menu_admin_kampanye" name="Kampanye Promo" parent="menu_admin_master" action="action_pipinos_kampanye" sequence="3"/>
    <menuitem id="menu_admin_segmen" name="Segmen Pelanggan" parent="menu_admin_master" action="action_pipinos_segmen" sequence="5"/>
    <menuitem id="menu_admin_point_conversion_config" name="Konfigurasi Konversi Poin" parent="menu_admin_master" action="action_pipinos_point_conversion_config" sequence="6"/>
    <menuitem id="menu_admin_loyalty_level_config" name="Konfigurasi Status Level" parent="menu_admin_master" action="action_pipinos_loyalty_level_config" sequence="7"/>
    <menuitem id="menu_admin_transaksi" name="Riwayat Transaksi" parent="menu_admin_master" action="action_pipinos_transaksi" sequence="8"/>
    <menuitem id="menu_admin_loyalty" name="Sistem Loyalty" parent="menu_admin_master" action="action_pipinos_loyalty" sequence="9"/>

    <menuitem id="menu_admin_dashboard_root" name="Dashboard Analitik" parent="menu_admin_root" sequence="3"/>
    <menuitem id="menu_admin_dashboard_age_gender" name="Avg Usia per Gender" parent="menu_admin_dashboard_root" action="action_pipinos_dashboard_age_gender" sequence="1"/>
    <menuitem id="menu_admin_dashboard_gender_count" name="Count per Gender" parent="menu_admin_dashboard_root" action="action_pipinos_dashboard_gender_count" sequence="2"/>
    <menuitem id="menu_admin_dashboard_segment" name="Segmen Pelanggan" parent="menu_admin_dashboard_root" action="action_pipinos_dashboard_segment" sequence="3"/>
    <menuitem id="menu_admin_dashboard_visit_frequency" name="Frekuensi Kunjungan" parent="menu_admin_dashboard_root" action="action_pipinos_dashboard_visit_frequency" sequence="4"/>
    <menuitem id="menu_admin_dashboard_status_level" name="Count Status Level" parent="menu_admin_dashboard_root" action="action_pipinos_dashboard_status_level" sequence="5"/>
    <menuitem id="menu_admin_dashboard_favorite_menu" name="Menu Favorit Pelanggan" parent="menu_admin_dashboard_root" action="action_pipinos_dashboard_favorite_menu" sequence="6"/>
    <menuitem id="menu_admin_dashboard_menu_count" name="Count per Menu" parent="menu_admin_dashboard_root" action="action_pipinos_dashboard_menu_count" sequence="7"/>
    
    <menuitem id="menu_kasir_root" name="Kasir (Operasional)" parent="menu_pipinos_root" sequence="2"/>
    <menuitem id="menu_kasir_loyalty" name="Sistem Loyalty" parent="menu_kasir_root" action="action_pipinos_loyalty" sequence="3"/>
</odoo>